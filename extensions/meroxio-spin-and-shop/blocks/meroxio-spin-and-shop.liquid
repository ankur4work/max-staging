{%render 'meroxio-spin-and-shop'%}
{% schema %}
{
  "name": "Spin And Shop",
  "target": "body",
  "stylesheet": "meroxio-spin-and-shop.css",
  "javascript": "meroxio-spin-and-shop.js",
  "settings": [
    {
      "type": "checkbox",
      "id": "sameProduct",
      "label": "Same Product For All",
      "default":true
    },
    {
      "type": "checkbox",
      "id": "isSpin",
      "label": "Would you like it to spin automatically the first time?",
      "default":true
    },
    {
      "type": "color",
      "id": "textColor",
      "label": "Color",
      "default":"#000"
    },
    {
      "type": "color",
      "id": "buttonBg",
      "label": "Butto Color",
      "default":"#000"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading"
    },
    {
      "type": "product",
      "id": "main_product",
      "label": "Main Product"
    },
    {
      "type": "product_list",
      "id": "product1",
      "label": "Product 1"
    }, {
      "type": "product_list",
      "id": "product2",
      "label": "Product 2"
    }, {
      "type": "product_list",
      "id": "product3",
      "label": "Product 3"
    },
    {
      "type": "text",
      "id": "mrpLabel",
      "label": "MRP Label",
      "default":"MRP"
    },
    {
      "type": "text",
      "id": "jackpotPriceLabel",
      "label": "Actual Price Label",
      "default":"Deal Price"
    },
    {
      "type": "text",
      "id": "discountedLabel",
      "label": "Discounted Price Label",
      "default":"You Save"
    }
  ]
}
{% endschema %}

