{% render 'meroxio-spin-and-shop-free' %}
{% schema %}
  {
    "name": "Spin And Shop Free",
    "target": "body",
    "stylesheet": "meroxio-spin-and-shop-free.css",
    "javascript": "meroxio-spin-and-shop-free.js",
    "settings": [

      {
        "type": "checkbox",
        "id": "isSpin",
        "label": "Would you like it to spin automatically the first time?",
        "info": "Change this to 'Spin Automatically 1st time'",
        "default": true
      },

      {
        "type": "product",
        "id": "main_product",
        "label": "Jackpot product"
      },
      {
        "type": "header",
        "content": "Slot Product Lists"
      },
      {
        "type": "product_list",
        "id": "product1",
        "label": "Slot 1 Product List"
      }, {
        "type": "checkbox",
        "id": "sameProduct",
        "label": "Use Same Products for all slots",
        "default": true
      }, {
        "type": "product_list",
        "id": "product2",
        "label": "Slot 2 Product List"
      }, {
        "type": "product_list",
        "id": "product3",
        "label": "Slot 3 Product List"
      }, {
        "type": "text",
        "id": "mrpLabel",
        "label": "Total Compared Price Label",
        "default": "MRP"
      }, {
        "type": "text",
        "id": "jackpotPriceLabel",
        "label": "Total Final Price Label",
        "default": "Deal Price"
      }, {
        "type": "text",
        "id": "discountedLabel",
        "label": "Total Saving Label",
        "default": "You Save"
      }, {
        "type": "header",
        "content": "Design Settings 🪄"
      }, {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Spin the Jackpot! 🎰"
      }, {
        "type": "text",
        "id": "sub_heading",
        "label": "Sub Heading",
        "default": "Spin to Win Toys for your 0-12 month old👶🎁"
      }, {
        "type": "color",
        "id": "textColor",
        "label": "Text Color",
        "default": "#000000"
      }, {
        "type": "color",
        "id": "buttonBg",
        "label": "ATC Button Background",
        "default": "#000000"
      }, {
        "type": "color",
        "id": "compared_price_color",
        "label": "Total Compared Price Text color",
        "default": "#f00000"
      }, {
        "type": "color",
        "id": "final_price_color",
        "label": "Total Final Price Text Color",
        "default": "#000000"
      }, {
        "type": "color",
        "id": "saving_price_color",
        "label": "Total Saving text Color",
        "default": "#058d05"
      }
    ]
  }
{% endschema %}