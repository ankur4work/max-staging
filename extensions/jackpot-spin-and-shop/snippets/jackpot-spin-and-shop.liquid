<style > :root
{
  --image-ratio-mobile: 100px;
  --image-ratio-desktop: 200px;
}

.slots-{{- block.id -}}{
  display: flex;
  justify-content: space-between;
  width: -moz-max-content;
  width: max-content;
  height: var(--image-ratio-mobile);
  gap: 1rem;
  margin-inline: auto;
}
@media(min-width: 768px) {
  .slots-{{- block.id -}}{
    height: var(--image-ratio-desktop);
  }
}

.slot-{{- block.id -}}{
  width: var(--image-ratio-mobile);
  overflow: hidden;
  border: 1px solid #e3e3e3;
  border-radius: 10px;
}
@media(min-width: 768px) {
  .slot-{{- block.id -}}{
    width: var(--image-ratio-desktop);
  }
}

ul.list-{{- block.id -}}{
  list-style: none;
  padding: 0;
  margin: 0;
  position: relative;
  top: 0;
  transition: top 1.5s ease-out;
}

li.product-{{- block.id -}}{
  height: var(--image-ratio-mobile);
  align-items: center;
  justify-content: center;
  font-size: 2em;
  background-color: #f9f9f9;
  position: relative;
}
@media(min-width: 768px) {
  li.product-{{- block.id -}}{
    height: var(--image-ratio-desktop);
  }
}

.product-image-{{- block.id -}}{
  display: flex;
  height: 100%;
  width: 100%;
}

#spinButton-{{- block.id -}}{
  display: block;
  text-align: center;
}

img.spin-images {
  width: 80px;
  height: auto;
  margin-inline: auto;
}
@media(min-width: 768px) {
  img.spin-images {
    width: 100px;
  }
}

section.m-container {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}
@media(min-width: 768px) {
  section.m-container {
    grid-template-columns: 1fr 1fr;
  }
}

.slot-item-details-{{- block.id -}} {
  position: absolute;
  inset: 0;
  top: unset;
  background: rgba(240, 248, 255, 0.4705882353);
}

h5.product-title {
  margin: 10px;
  line-height: 1;
  color: #000;
}

p.product-price-{{-block.id-}} {
  margin: 10px;
  line-height: 1;
  color: #000;
}

h5.product-title a {
  color: currentColor;
  text-decoration: unset;
}

button#add-to-cart-button-{{- block.id -}}{
  background: #000;
  color: #fff;
  border: none;
  height: 40px;
  padding-inline: 3rem;
  text-transform: uppercase;
  border-radius: 5px;
}

.text-center {
  text-align: center;
} 
.jackpot-product-details {
    text-align: center;
}
.mrp-price {
    color: red;
}

.save-price {
    color: green;
}

.deal-price {
    color: #d5932e;
}
</style>
{% assign block.id = block.id %}{% assign product_list_1 = block.settings.product1 %}{% assign product_list_2 = block.settings.product2 %}{% assign product_list_3 = block.settings.product3 %}<section class="m-container">
<div class="section-left">
  <div class="slots-{{-block.id-}}">
    <div class="slot-{{-block.id-}}">
      <ul class="list-{{-block.id-}}">
        {% for product in product_list_1 %}

          <li data-title="{{ product.title }}" class="product-{{- block.id -}}">
            <img
              class="product-image-{{-block.id-}}"
              width="200"
              height="200"
              src="https://img.freepik.com/premium-photo/oily-paints-light-strokes-realistic-beautiful-cute-squirrel-dancing-branch_933786-1747.jpg"
              loading="lazy">
            <div class="slot-item-details-{{- block.id -}}">
              <h5 class="product-title">{{ product.title | link_to: product.url }}</h5>
              <p
                style="font-size: 12px;"
                class="product-price-{{-block.id-}} "
                data-price="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | divided_by: 100 }}{% else %}{{ product.price  | divided_by: 100 }}{% endif %}">MRP :
                {% if product.compare_at_price > product.price %}
                  {{ product.compare_at_price | money_without_currency }}
                {% else %}
                  {{ product.price | money_without_currency }}{% endif %}
              </p>
            </div>
          </li>
        {% endfor %}

      </ul>
    </div>

    <div class="slot-{{-block.id-}}">
      <ul class="list-{{-block.id-}}">
        {% for product in product_list_1 %}
          <li data-title="{{ product.title }}" class="product-{{- block.id -}}">
            <img
              class="product-image-{{-block.id-}}"
              width="200"
              height="200"
              src="https://img.freepik.com/premium-photo/oily-paints-light-strokes-realistic-beautiful-cute-squirrel-dancing-branch_933786-1747.jpg"
              loading="lazy">
            <div class="slot-item-details-{{- block.id -}}">
              <h5 class="product-title">{{ product.title | link_to: product.url }}</h5>
              <p
                style="font-size: 12px;"
                class="product-price-{{-block.id-}} "
                data-price="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | divided_by: 100 }}{% else %}{{ product.price  | divided_by: 100 }}{% endif %}">MRP :
                {% if product.compare_at_price > product.price %}
                  {{ product.compare_at_price | money_without_currency }}
                {% else %}
                  {{ product.price | money_without_currency }}{% endif %}
              </p>
            </div>
          </li>
        {% endfor %}

      </ul>
    </div>

    <div class="slot-{{-block.id-}}">
      <ul class="list-{{-block.id-}}">
        {% for product in product_list_1 %}
          <li data-title="{{ product.title }}" class="product-{{- block.id -}}">
            <img
              class="product-image-{{-block.id-}}"
              width=""
              height=""
              alt=""
              src="https://img.freepik.com/premium-photo/oily-paints-light-strokes-realistic-beautiful-cute-squirrel-dancing-branch_933786-1747.jpg"
              loading="lazy">
            <div class="slot-item-details-{{- block.id -}}">
              <h5 class="product-title">{{ product.title | link_to: product.url }}</h5>
              <p
                style="font-size: 12px;"
                class="product-price-{{-block.id-}} "
                data-price="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | divided_by: 100 }}{% else %}{{ product.price  | divided_by: 100 }}{% endif %}">MRP :
                {% if product.compare_at_price > product.price %}
                  {{ product.compare_at_price | money_without_currency }}
                {% else %}
                  {{ product.price | money_without_currency }}{% endif %}
              </p>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>
<div class="section-right">
  <span id="spinButton-{{-block.id-}}">
    <img
      id="spin-up-{{-block.id-}}"
      src="https://cdn.shopify.com/s/files/1/0257/0007/3550/files/spin-up.png"
      width="100"
      height="100"
      alt=""
      class="spin-images"
      loading="lazy">
    <img
      id="spin-down-{{-block.id-}}"
      style="display: none;"
      src="https://cdn.shopify.com/s/files/1/0257/0007/3550/files/spin-down.png"
      width="100"
      height="100"
      loading="lazy"
      class="spin-images"
      alt="">
  </span>
  <div class="jackpot-product-details">
    <div class="mrp-price"><span id="mrp-price-{{-block.id}}"></span></div>
    <div class="deal-price">Deal Price : <span id="deal-price-{{-block.id}}">120</span></div>
    <div class="save-price"><span id="save-price-{{-block.id}}"></span></div>
  </div>
  <div class="text-center">
    <button id="add-to-cart-button-{{-block.id-}}">Add To Cart</button>
  </div>
</div></section><script>
"use strict";
document.addEventListener("DOMContentLoaded", function() {
  const spin_btn = document.querySelector("#spinButton-{{-block.id-}}");
  const listContainer = document.querySelector(".list-{{-block.id-}}");
  const listItems = listContainer.querySelectorAll("li");
  const totalItems = listItems.length;
  let dealPrice = document.querySelector("#deal-price-{{-block.id}}").textContent

  let totalPrice = 0;
  let itemHeight = 200;
  if (window.innerWidth < 768) {
    itemHeight = 100;
  }
  if (spin_btn) {
    spin_btn.addEventListener("click", function(e) {
      const slots = document.querySelectorAll(".slot-{{-block.id-}}");
      let indices = Array.from({
        length: totalItems
      }, (_, i) => i);

      slots.forEach(slot => {
        const list = slot.querySelector(".list-{{-block.id-}}");
        const randomIndex = Math.floor(Math.random() * indices.length);
        const chosenIndex = indices[randomIndex];
        indices = indices.filter((_, i) => i !== randomIndex);

        const offset = - chosenIndex * itemHeight;
        list.style.top = `${offset}px`;

        list.addEventListener("transitionend", () => {
          const activeItem = list.children[chosenIndex];
          const previousActiveItem = slot.querySelector(".activeProduct-  {{-block.id-}}");
          if (previousActiveItem) {
            previousActiveItem.classList.remove("activeProduct-{{-block.id-}}");
            previousActiveItem.classList.remove("activeJackpotProduct");
          }
          activeItem.classList.add("activeProduct-{{-block.id-}}");
          activeItem.classList.add("activeJackpotProduct");
          totalPrice = 0;
          const items = document.querySelectorAll(".activeJackpotProduct .product-price-{{-block.id-}}[data-price]");
          // console.log(items)
          items.forEach(function(element) {
            const price = parseFloat(element.getAttribute("data-price"));
            if (!isNaN(price)) {
              totalPrice += price;
            }
          });
          console.log(dealPrice)  
          const slotComparePrice = document.querySelector("#mrp-price-{{-block.id}}");
          if (slotComparePrice) {
            slotComparePrice.textContent = `MRP : ₹${totalPrice}`;
          }
          const normalPrice = document.querySelector(".normalPrice-{{-block.id-}}");
          if (normalPrice) {
            if (dealPrice > totalPrice) {
              normalPrice.textContent = '';
              slotComparePrice.textContent = '';
              normalPrice.style.display = 'none';
            } else {
              normalPrice.style.display = 'block';
            }
          }
          const saveAmt = totalPrice - dealPrice;
          const discountPercentage = (totalPrice - dealPrice) / totalPrice;
          const finalDiscountPercentage = discountPercentage * 100;
          const slotSaveAmt = document.querySelector("#save-price-{{-block.id-}}");
          if (slotSaveAmt) {
            slotSaveAmt.textContent = `🥳 You Save : ₹${saveAmt} (${
              Math.ceil(finalDiscountPercentage)
            }% Off) 🥳`;
          }
        }, {once: true});
      });
    });
  }
});


// button click
document.body.addEventListener("touchstart", function(event) {
  if (event.target.id === "spinButton-{{-block.id-}}") {
    document.querySelector("#spin-up-{{-block.id-}}").style.display = "none";
    document.querySelector("#spin-down-{{-block.id-}}").style.display = "block";
  }
});

document.body.addEventListener("touchend", function(event) {
  if (event.target.id === "spinButton-{{-block.id-}}") {
    document.querySelector("#spin-down-{{-block.id-}}").style.display = "none";
    document.querySelector("#spin-up-{{-block.id-}}").style.display = "block";
  }
});

document.body.addEventListener("mousedown", function(event) {
  if (event.target.id === "spinButton-{{-block.id-}}") {
    document.querySelector("#spin-up-{{-block.id-}}").style.display = "none";
    document.querySelector("#spin-down-{{-block.id-}}").style.display = "block";
  }
});

document.body.addEventListener("mouseup", function(event) {
  if (event.target.id === "spinButton-{{-block.id-}}") {
    document.querySelector("#spin-down-{{-block.id-}}").style.display = "none";
    document.querySelector("#spin-up-{{-block.id-}}").style.display = "block";
  }
});

// 44937506423083

</script>
<script>
document.addEventListener("DOMContentLoaded", function() {
  const addToCartButton = document.querySelector("#add-to-cart-button-{{-block.id-}}");
addToCartButton.addEventListener('click', async (event) => {
  try {
    const props = {};
    const selectedProducts = document.querySelectorAll(".activeProduct-{{-block.id-}}");
    selectedProducts.forEach((product, index) => {
      const propTitle = product.getAttribute("data-title");
      props[`Product ${index + 1}`] = `${propTitle}`;
    });
    const requestData = {
      quantity: 1,
      id: 44937506423083,
      properties: props
    };

    const response = await fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(requestData)
    });

    if (response.ok) {
      const data = await response.json();
      window.location.href = '/cart';
    } else {
      console.error('Error:', response.statusText);
    }
  } catch (error) {
    console.error('Error:', error);
  }
});
})
</script>