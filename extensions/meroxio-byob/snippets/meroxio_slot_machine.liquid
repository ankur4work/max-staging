{% assign bundledProduct = block.settings.mainproduct %}
{% assign count = block.settings.count %}
{% assign m_currency = block.settings.m_currency %}

<style>
  {% if block.settings.themeName == 'impulse' %}
  .main-content {
    display: block;
    min-height: auto;
 } 
  {% endif %}
  .merox-product-section h2 {
    margin-block: 2rem 1rem;
}
  .sticky-nav-images {
    display: grid;
    grid-template-columns: repeat({{count}}, 1fr);
    column-gap: 8px;
  }
  .merox-product-qty button {
    background: {{ block.settings.atcBg }};
    aspect-ratio: 1 / 1;
  }
  .atc-wrapper {
  background: {{ block.settings.atcBg }};
  margin-block: 10px;
  width: calc(100% - 20px);
  margin-inline: auto;
  min-height: 40px;
   }
.bundleBtnSpinnerWrapper{
  height: 35px;
  display: grid;
  place-content: center;
}
  button#bundaledAddToCart {
    padding: 0 1rem;
    width: max-content;
    border-radius: 5px;
    outline: none;
    border: none;
    cursor: pointer;
    height: 30px;
    {% if block.settings.atcBg != blank %}
      background: {{ block.settings.atcBg}}
      ;
    {% else %}
      background: #000;
    {% endif %}
    {% if block.settings.atcColor != blank %}
      color: {{ block.settings.atcColor}}
    {% else %}
      color: #fff;
    {% endif %}

  }
  @media(max-width:767px) {

    .sticky-nav-images {
      display: flex;
      column-gap: 5px;
      justify-content: center;
      width: 100%;
      padding-inline: 5px 3rem;
    }
    .merox-product-navigation {
      gap: 5px;
    }
  }
</style>
{% if block.settings.banner != blank %}
  <img
    cla
    loading="lazy"
    width="1800"
    height="1800"
    class="merox-banner-img"
    src="{{ block.settings.banner | image_url : width: 1800 }}"
    alt="{{ image.alt }}">
{% endif %}
<section
  class="merox-product-wrapper"
  {% if block.settings.currency != blank %}
  themeCurrency="{{ block.settings.currency }}"
  {%  else %}
  themeCurrency="{% for currency in shop.enabled_currencies %}{% if currency.iso_code == shop.currency %}{{ currency.symbol }}{% break %}{% endif %}{% endfor %}"
  {% endif %}
  productAllowed="{{ count }}"
  placeholderImage="{{ 'placeholder-images-collection.png' | asset_url }}"
  bundledProductId="{{ bundledProduct.selected_or_first_available_variant.id }}">
  <div class="merox-product-navigation">
    <div class="sticky-nav-images">
      {% for num in (1..count) %}
        <div
          class="m-empty"
          productid=""
          productprice=""
          productPriceInteger="">

          <img
            loading="lazy"
            width="80"
            height="80"
            class="merox-product-img"
            src="{{ 'placeholder-images-collection.png' | asset_url }}"
            alt="{{ image.alt }}">
          <span class="selectedProductPrice"></span>
        <span class="removeProductFromNavigationBar">✕</span>
        </div>
      {% endfor %}
    </div>
    <div class="m-equal-icon" style="font-size: 30px;">
      =
    </div>
    <div class="m-sticky-price">
      <div id="actualPrice" actualPrice="{{bundledProduct.price | money_without_currency}}">{{ bundledProduct.price | money }}</div>
      <del id="totalPrice"></del>
      <div id="savedMoneyPercent"></div>
    </div>
    {% if block.settings.themeName == 'prestige' %}
      <button
        id="bundaledAddToCart"
        class=""
        data-action="open-drawer" aria-expanded="false" aria-label="Open cart"
        data-drawer-id="sidebar-cart"
        disabled>
        <span id="btnText">Add To Cart
        </span>
        <span id="m_spinner" class="m-hidden"></span>
      </button>
      <button id="clearAllProduct" class="clearAllProduct">
        <span class="textClear">Clear All</span>

        <svg
          style="display:none;"
          xmlns="http://www.w3.org/2000/svg"
          height="30"
          fill="#f00000"
          viewBox="0 96 960 960"
          width="30"><path d="m330 768 150-150 150 150 42-42-150-150 150-150-42-42-150 150-150-150-42 42 150 150-150 150 42 42Zm150 208q-82 0-155-31.5t-127.5-86Q143 804 111.5 731T80 576q0-83 31.5-156t86-127Q252 239 325 207.5T480 176q83 0 156 31.5T763 293q54 54 85.5 127T880 576q0 82-31.5 155T763 858.5q-54 54.5-127 86T480 976Zm0-60q142 0 241-99.5T820 576q0-142-99-241t-241-99q-141 0-240.5 99T140 576q0 141 99.5 240.5T480 916Zm0-340Z" /></svg>
      </button>
    {% else %}
      <button
        id="bundaledAddToCart"
        class=""
        disabled>
        <span id="btnText">Add To Cart
        </span>
        <span id="m_spinner" class="m-hidden"></span>
      </button>
      <button id="clearAllProduct" class="clearAllProduct">
        <span class="textClear">Clear All</span>

        <svg
          style="display:none;"
          xmlns="http://www.w3.org/2000/svg"
          height="30"
          fill="#f00000"
          viewBox="0 96 960 960"
          width="30"><path d="m330 768 150-150 150 150 42-42-150-150 150-150-42-42-150 150-150-150-42 42 150 150-150 150 42 42Zm150 208q-82 0-155-31.5t-127.5-86Q143 804 111.5 731T80 576q0-83 31.5-156t86-127Q252 239 325 207.5T480 176q83 0 156 31.5T763 293q54 54 85.5 127T880 576q0 82-31.5 155T763 858.5q-54 54.5-127 86T480 976Zm0-60q142 0 241-99.5T820 576q0-142-99-241t-241-99q-141 0-240.5 99T140 576q0 141 99.5 240.5T480 916Zm0-340Z" /></svg>
      </button>
    {% endif %}
  </div>
  <div class="merox-product-section">
    <h2>
      <strong>{{ block.settings.heading | upcase }}</strong>
    </h2>
    <div class="merox-product">
      {% if block.settings.productSource == 'collection' %}
      {% for productItem in collections[block.settings.meroxCollection].products %}
        {% if productItem.available %}
        {% unless productItem.variants.size > 1 %}
        <div
          class="merox-product-item"
          productID={{productItem.selected_or_first_available_variant.id}}
          productTitle='{{productItem.title}}'
          productPrice='{{productItem.price |money}}'
          productPriceInteger='{{productItem.price | money_without_currency}}'
          productVariantName="{{ productItem.selected_or_first_available_variant.title | upcase }}">
          <a href={{productItem.url}}><img
              loading="lazy"
              width="200"
              height="200"
              class="merox-product-img"
              src="{{ productItem.featured_image | image_url : width: 200 }}"
              alt="{{ image.alt }}"></a>
          <p style="padding-inline: 10px;">
            <a href={{ productItem.url }}> <strong>{{ productItem.title }}</strong></a>
          </p>
          <div style="display: grid;grid-template-columns: 1fr 1fr; padding-inline: 10px;">
            <p class="merox-price">
              <span class="productItemPrice">{{ productItem.price | money }}</span>
              {% if productItem.compare %}
                <span class="productItemComparePrice">
                  <del>{{ productItem.compare | money }}</del>
                </span>
              {% endif %}
            </p>
          </div>
          
            <div class="m-variants">
              {% if productItem.variants.size > 1 %}
              <select class="m-variant-dropdown">
                {% for variant in productItem.variants %}
                  <option
                    value="{{ variant.id }}"
                    variantPrice="{{ variant.price | money_without_currency }}"
                    variantTitle="{{ variant.title | downcase }}"
                    variantId="{{ variant.id }}"
                    {% unless variant.available %}disabled{% endunless %}>{{ variant.title | upcase }}</option>
                {% endfor %}
              </select>
              {% endif %}
            </div>

            <div class="atc-wrapper">
              <button class="add-to-bundle">Add To Bundle</button>
            </div>
        </div>
        {% endunless %}
      {% endif %}
      {% endfor %}
        {% for productItem in collections[block.settings.meroxCollection].products %}
          {% if productItem.available %}
          {% if productItem.variants.size > 1 %}
          <div
            class="merox-product-item"
            productID={{productItem.selected_or_first_available_variant.id}}
            productTitle='{{productItem.title}}'
            productPrice='{{productItem.price |money}}'
            productPriceInteger='{{productItem.price | money_without_currency}}'
            productVariantName="{{ productItem.selected_or_first_available_variant.title | upcase }}">
            <a href={{productItem.url}}><img
                loading="lazy"
                width="200"
                height="200"
                class="merox-product-img"
                src="{{ productItem.featured_image | image_url : width: 200 }}"
                alt="{{ image.alt }}"></a>
            <p style="padding-inline: 10px;">
              <a href={{ productItem.url }}> <strong>{{ productItem.title }}</strong></a>
            </p>
            <div style="display: grid;grid-template-columns: 1fr 1fr; padding-inline: 10px;">
              <p class="merox-price">
                <span class="productItemPrice">{{ productItem.price | money }}</span>
                {% if productItem.compare %}
                  <span class="productItemComparePrice">
                    <del>{{ productItem.compare | money }}</del>
                  </span>
                {% endif %}
              </p>
            </div>
            
              <div class="m-variants">
                {% if productItem.variants.size > 1 %}
                <select class="m-variant-dropdown">
                  {% for variant in productItem.variants %}
                    <option
                      value="{{ variant.id }}"
                      variantPrice="{{ variant.price | money_without_currency }}"
                      variantTitle="{{ variant.title | downcase }}"
                      variantId="{{ variant.id }}"
                      {% unless variant.available %}disabled{% endunless %}>{{ variant.title | upcase }}</option>
                  {% endfor %}
                </select>
                {% endif %}
              </div>

              <div class="atc-wrapper">
                <button class="add-to-bundle">Add To Bundle</button>
              </div>
          </div>
          {% endif %}
        {% endif %}
        {% endfor %}

      {% endif %}
      {% if block.settings.productSource == 'ProductList' %}
        {% for productItem in block.settings.productList %}
          {% if productItem.available %}
          {% unless productItem.variants.size > 1 %}
          <div
            class="merox-product-item"
            productID={{productItem.selected_or_first_available_variant.id }}
            productTitle='{{ productItem.title }}'
            productPrice='{{ productItem.price | money }}'
            productPriceInteger='{{ productItem.price | money_without_currency }}'
            productVariantName="{{ productItem.selected_or_first_available_variant.title }}">
            <a href={{ productItem.url }}><img
                loading="lazy"
                width="200"
                height="200"
                class="merox-product-img"
                src="{{ productItem.featured_image | image_url : width: 200 }}"
                alt="{{ image.alt }}"></a>
            <p style="padding-inline: 10px;">
              <a href={{ productItem.url }}> <strong>{{ productItem.title }}</strong></a>
            </p>
            <div style="display: grid;grid-template-columns: 1fr 1fr; padding-inline: 10px;">
              <p class="merox-price">
                <span>{{ productItem.price | money }}</span>
                <span>{{ productItem.compare | money }}</span>
              </p>
              
                <div class="m-variants">
                  {% if productItem.variants.size > 1 %}
                  <select class="m-variant-dropdown">
                    {% for variant in productItem.variants %}
                      <option
                        value="{{ variant.id }}"
                        variantPrice="{{ variant.price | money_without_currency }}"
                        variantTitle="{{ variant.title | downcase }}"
                        variantId="{{ variant.id }}"
                        {% unless variant.available %}disabled{% endunless %}>{{ variant.title | upcase }}</option>
                    {% endfor %}
                  </select>
                  {% endif %}
                  </select>
                </div>
                <div class="atc-wrapper">
                  <button class="add-to-bundle">Add To Bundle</button>
                </div>
            </div>
          </div>
          {% endunless %}
        {% endif %}
          
        {% endfor %}
        {% for productItem in block.settings.productList %}
          {% if productItem.available %}
          {% if productItem.variants.size > 1 %}
          <div
            class="merox-product-item"
            productID={{productItem.selected_or_first_available_variant.id }}
            productTitle='{{ productItem.title }}'
            productPrice='{{ productItem.price | money }}'
            productPriceInteger='{{ productItem.price | money_without_currency }}'
            productVariantName="{{ productItem.selected_or_first_available_variant.title }}">
            <a href={{ productItem.url }}><img
                loading="lazy"
                width="200"
                height="200"
                class="merox-product-img"
                src="{{ productItem.featured_image | image_url : width: 200 }}"
                alt="{{ image.alt }}"></a>
            <p style="padding-inline: 10px;">
              <a href={{ productItem.url }}> <strong>{{ productItem.title }}</strong></a>
            </p>
            <div style="display: grid;grid-template-columns: 1fr 1fr; padding-inline: 10px;">
              <p class="merox-price">
                <span>{{ productItem.price | money }}</span>
                <span>{{ productItem.compare | money }}</span>
              </p>
              
                <div class="m-variants">
                  {% if productItem.variants.size > 1 %}
                  <select class="m-variant-dropdown">
                    {% for variant in productItem.variants %}
                      <option
                        value="{{ variant.id }}"
                        variantPrice="{{ variant.price | money_without_currency }}"
                        variantTitle="{{ variant.title | downcase }}"
                        variantId="{{ variant.id }}"
                        {% unless variant.available %}disabled{% endunless %}>{{ variant.title | upcase }}</option>
                    {% endfor %}
                  </select>
                  {% endif %}
                  </select>
                </div>
                <div class="atc-wrapper">
                  <button class="add-to-bundle">Add To Bundle</button>
                </div>
            </div>
          </div>
          {% endif %}
        {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
<dialog id="my-dialog">
  <h3>{{ block.settings.dialogMessage }}</h3>
  <button id="close-dialog">OK</button>
</dialog>

<script>
  async function bundaledAddToCart(variantId, element, props) {
    const spinner = document.getElementById('m_spinner');
    const btnText = document.getElementById('btnText');
    const result = await fetch("/cart/add.json", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      body: JSON.stringify(
        {id: variantId, quantity: 1, properties: props}
      )
    }).then((response) => response.json()).then((data) => {
      {% if block.settings.themeName == 'prestige' %}
      btnText.style.display = 'inline-block';
      spinner.style.display = 'none';
      document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', {
        bubbles: true  //this code is for prestige theme, is to refresh the cart
      }));
      {% elsif block.settings.themeName == 'impulse' %}
        btnText.style.display = 'inline-block';
        spinner.style.display = 'none';
        var cart = new theme.CartDrawer
        cart.init()
        cart.open();
      {% else %}
      btnText.style.display = 'inline-block';
      spinner.style.display = 'none'; 
      window.location.href = ("/cart");

      {% endif %}
    });
  }
</script>