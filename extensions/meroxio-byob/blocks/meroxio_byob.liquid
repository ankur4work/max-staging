{% render 'meroxio_byob_snippet' %}
{% schema %}
  {
    "name": "MeroxIo BYOB",
    "target": "section",
    "stylesheet": "meroxio_byob.css",
    "javascript": "meroxio_byob.js",
    "settings": [
      {
        "type": "header",
        "content": "Section Settings"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "MeroxIo BYOB"
      },
      {
        "type": "image_picker",
        "id": "banner",
        "label": "Banner Image"
      },
      {
        "type": "range",
        "id": "count",
        "min": 2,
        "max": 5,
        "step": 1,
        "label": "Product Limit",
        "unit": "Pcs",
        "default": 2
      }, {
        "type": "select",
        "id": "productSource",
        "label": "Product Source",
        "info": "The product selection will be displayed based on your choice.",
        "options": [
          {
            "value": "collection",
            "label": "By Collection"
          }, {
            "value": "ProductList",
            "label": "By Product List"
          }
        ],
        "default": "collection"
      }, {
        "type": "collection",
        "id": "meroxCollection",
        "label": "Collection",
        "info": "Please select product collection for bundle."
      }, {
        "type": "product_list",
        "id": "productList",
        "label": "Product List",
        "info": "Please select product for bundle."

      }, {
        "type": "header",
        "content": "Main Product"
      },
      {
        "type": "paragraph",
        "content": "This is the primary product that will be added to your cart."
      },
      {
        "type": "product",
        "id": "mainproduct",
        "label": " Main Product",
        "info": "Select a bundled product which will be to add to cart."
      }, {
        "type": "header",
        "content": "Designing Settings ⚙️"
      }, {
        "type": "color",
        "id": "atcBg",
        "label": "Button Background Color",
        "default": "#000000"
      }, {
        "type": "color",
        "id": "atcColor",
        "label": "Button Text Color",
        "default": "#ffffff"
      }, {
        "type": "header",
        "content": "Developer Settings ⚙️"
      }, {
        "type": "select",
        "id": "themeName",
        "label": "Select Your Theme",
        "info": "If you select others, the page will redirect to cart page",
        "options": [
          {
            "value": "prestige",
            "label": "Prestige"
          }, {
            "value": "dawn",
            "label": "Dawn"
          }, {
            "value": "impulse",
            "label": "Impulse"
          }, {
            "value": "others",
            "label": "Others"
          }
        ],
        "default": "others"
      }, {
        "type": "textarea",
        "id": "dialogMessage",
        "label": "Disclaimer",
        "default": "You Have Already Reach The Limit ."
      }, {
        "type": "text",
        "id": "m_currency",
        "label": "Currency Symbol",
        "info": "Enter store currency symbol"
      }, {
        "type": "image_picker",
        "id": "placeholderImage",
        "label": "Place Holder Item's Image"
      }
    ]
  }
{% endschema %}