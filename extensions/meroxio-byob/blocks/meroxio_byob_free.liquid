{% render 'meroxio_byob_snippet_free' %}
{% schema %}
  {
    "name": "MEROXIO BYOB FREE",
    "target": "section",
    "stylesheet": "meroxio_byob_free.css",
    "javascript": "meroxio_byob_free.js",
    "settings": [
      {
        "type": "header",
        "content": "Section Settings"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "MEROXIO BYOB FREE"
      },
      {
        "type": "image_picker",
        "id": "banner",
        "label": "Banner Image"
      },
      {
        "type": "select",
        "id": "productSource",
        "label": "Product Source",
        "info": "The product selection will be displayed based on your choice.",
        "options": [
          {
            "value": "collection",
            "label": "By Collection"
          }, {
            "value": "ProductList",
            "label": "By Product List"
          }
        ],
        "default": "collection"
      }, {
        "type": "collection",
        "id": "meroxCollection",
        "label": "Collection",
        "info": "Please select product collection for bundle."
      }, {
        "type": "product_list",
        "id": "productList",
        "label": "Product List",
        "info": "Please select product for bundle."

      },
      {
        "type": "header",
        "content": "Main Product"
      },
      {
        "type": "paragraph",
        "content": "This is the primary product that will be added to your cart."
      },
      {
        "type": "product",
        "id": "mainproduct",
        "label": " Main Product",
        "info": "Select a bundled product which will be to add to cart."
      }, {
        "type": "header",
        "content": "Designing Settings ⚙️"
      }, {
        "type": "color",
        "id": "atcBg",
        "label": "Button Background Color",
        "default": "#000000"
      }, {
        "type": "color",
        "id": "atcColor",
        "label": "Button Text Color",
        "default": "#ffffff"
      }, {
        "type": "header",
        "content": "Developer Settings ⚙️"
      },  {
        "type": "textarea",
        "id": "dialogMessage",
        "label": "Disclaimer",
        "default": "You Have Already Reach The Limit ."
      }, {
        "type": "text",
        "id": "currency",
        "label": "Currency Symbol",
        "info": "Enter store currency symbol"
      }
    ]
  }
{% endschema %}